@* Archivo: CRM.AplicacionWeb\Views\Account\ForgotPassword.cshtml
   Vista Razor para recuperar una contrasena olvidada. *@
@model CRM.AplicacionWeb.Models.Account.ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["AuthCss"] = "loginD.css";
}

<div class="cuadro cuadro-recuperar">
    <form method="post">
        @Html.AntiForgeryToken()
        <h1>Recuperar</h1>
        <p class="auth-help">Introduce tu usuario y email para crear una nueva contrasena.</p>
        <div asp-validation-summary="ModelOnly" class="legacy-validation"></div>

        <div class="caja">
            <input asp-for="UserName" placeholder="Usuario" required />
            <i class='bx bxs-user'></i>
        </div>
        <span asp-validation-for="UserName" class="legacy-validation"></span>

        <div class="caja">
            <input asp-for="Email" placeholder="Correo electronico" required />
            <i class='bx bxs-envelope'></i>
        </div>
        <span asp-validation-for="Email" class="legacy-validation"></span>

        <div class="caja">
            <input asp-for="NewPassword" placeholder="Nueva contrasena" required />
            <i class='bx bxs-lock-alt'></i>
        </div>
        <span asp-validation-for="NewPassword" class="legacy-validation"></span>

        <div class="caja">
            <input asp-for="ConfirmNewPassword" placeholder="Repetir nueva contrasena" required />
            <i class='bx bxs-lock-alt'></i>
        </div>
        <span asp-validation-for="ConfirmNewPassword" class="legacy-validation"></span>

        <button type="submit" class="boton">Cambiar contrasena</button>

        <div class="linkRegistro">
            <p><a asp-action="Login">Volver al login</a></p>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
